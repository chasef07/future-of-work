version = 1
id = "agent-os-source-adapter"
kind = "cron"
name = "Agent OS source signal ingest"
prompt = """
Agent OS source adapter heartbeat.

This automation is a source adapter, not a user-facing orchestrator thread. The
Agent OS ledger is the source of truth. Do not create, reuse, or steer worker
threads from this automation.

Agent OS checkout: `<AGENT_OS_CHECKOUT>`.
Source system checkout or command context: `<SOURCE_CONTEXT>`.

Goal: run cheap read-only checks for one source system, capture only meaningful
signals into Agent OS, route them into tasks, and stay terse.

For each meaningful signal, capture one Agent OS event:
`python3 -m agent_os.cli --db ./agent_os.sqlite capture --source <SOURCE_SLUG> "<short signal and recommended next action>"`

Then run:
`python3 -m agent_os.cli --db ./agent_os.sqlite route --limit 25`
`python3 -m agent_os.cli --db ./agent_os.sqlite brief`

Hard rules:
- Do not send, publish, approve, spend, deploy, delete, or mutate external systems.
- Do not print secrets, raw inbox dumps, raw private comments, private customer context, credentials, or full raw bodies.
- Report only meaningful Agent OS changes: event captured, task created, blocker, or no meaningful change.
"""
status = "PAUSED"
rrule = "FREQ=HOURLY;INTERVAL=12"
model = "<MODEL>"
reasoning_effort = "medium"
execution_environment = "local"
cwds = ["<AGENT_OS_CHECKOUT>", "<SOURCE_CHECKOUT>"]
